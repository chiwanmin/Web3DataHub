# Database
# Prisma SQLite URLs are resolved relative to schema.prisma, so "../dev.db"
# puts the file at the workspace root (next to package.json).
DATABASE_URL="file:../dev.db"

# Optional: GitHub token to lift API rate limit (60/h -> 5000/h)
GITHUB_TOKEN=""

# Optional: override default public RPC endpoints (comma-separated)
# RPC_ETHEREUM="https://eth.llamarpc.com,https://rpc.ankr.com/eth"
# RPC_BSC="https://bsc-dataseed.bnbchain.org"
# RPC_POLYGON="https://polygon-rpc.com"
# RPC_ARBITRUM="https://arb1.arbitrum.io/rpc"
# RPC_BITCOIN="https://api.blockchair.com/bitcoin"
# RPC_SOLANA="https://api.mainnet-beta.solana.com"
# RPC_TRON="https://api.trongrid.io"
# RPC_TON="https://toncenter.com/api/v2"

# Disable background scheduler (e.g. for tests / CI)
WEB3VIEW_DISABLE_SCHEDULER="false"
